# -*- coding: utf-8 -*-
"""
Music Eval v4 (7-in-1): symbolic evidence + rule metrics + deliberation + moderator + edit_plan + auto-edit loop + batch/cache/compare.
Input: .mid/.midi
Output: report_v4.json (rich), optional edited midi + after report + csv summaries.
"""

from __future__ import annotations

import argparse
import csv
import hashlib
import json
import os
