# -----------------------------
# Config / Judges
# -----------------------------

JUDGES = [
    {"name": "harmony_judge", "focus": "和声/乐理（基于音高集合、和弦/调性线索、声部进行）"},
    {"name": "rhythm_judge", "focus": "节奏/律动（基于拍网格、起音分布、切分、密度与稳定性）"},
    {"name": "structure_judge", "focus": "结构/段落（基于重复/对比、动机、密度与音域变化）"},
    {"name": "style_judge", "focus": "风格一致性/可听性（基于音域、跳进、织体、稳定性与目标风格）"},
]

DEFAULT_MODEL = "deepseek-chat"


# -----------------------------
# Utilities
# -----------------------------

def now_ts() -> int:
    return int(time.time())


def sha256_bytes(b: bytes) -> str:
    return hashlib.sha256(b).hexdigest()


def stable_json(obj: Any) -> str:
    return json.dumps(obj, ensure_ascii=False, sort_keys=True, separators=(",", ":"))


def safe_json_loads(text: str) -> Dict[str, Any]:
    try:
        return json.loads(text)
    except Exception:
        m = re.search(r"\{.*\}", text, flags=re.DOTALL)
        if not m:
            raise ValueError("No JSON object found in model output.")
        return json.loads(m.group(0))


def clamp_int(x: Any, lo: int, hi: int, default: int = 0) -> int:
    try:
        v = int(x)
    except Exception:
        v = default
    return max(lo, min(hi, v))


# -----------------------------
# MIDI: tempo/beat helpers
# -----------------------------

def time_signature(pm: pretty_midi.PrettyMIDI) -> Tuple[int, int]:
    if pm.time_signature_changes:
        ts = pm.time_signature_changes[0]
        return int(ts.numerator), int(ts.denominator)
    return 4, 4


def tempo_at(pm: pretty_midi.PrettyMIDI, t: float) -> float:
    times, tempi = pm.get_tempo_changes()
    if len(tempi) == 0:
        return 120.0
    i = bisect_right(list(times), t) - 1
    if i < 0:
        return float(tempi[0])
    return float(tempi[i])


def pick_main_instruments(pm: pretty_midi.PrettyMIDI, keep: int = 2, include_drums: bool = False) -> List[pretty_midi.Instrument]:
    insts = []
    for inst in pm.instruments:
        if inst.is_drum and not include_drums:
            continue
        insts.append((len(inst.notes), inst))
    insts.sort(key=lambda x: x[0], reverse=True)
    return [x[1] for x in insts[:keep]]


# -----------------------------
# Symbolic evidence (measure-level events + chord/key hints)
# -----------------------------

NOTE_NAMES = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"]
MAJOR_SCALE = {0,2,4,5,7,9,11}
MINOR_SCALE = {0,2,3,5,7,8,10}


def infer_triad(pitch_classes: List[int]) -> Optional[str]:
    pcs = set(pitch_classes)
    if not pcs:
        return None
    best = None
    best_score = 0
    for root in range(12):
        maj = {root, (root + 4) % 12, (root + 7) % 12}
        minr = {root, (root + 3) % 12, (root + 7) % 12}
        maj_score = len(pcs & maj)
        min_score = len(pcs & minr)
        if maj_score > best_score and maj_score >= 2:
            best_score = maj_score
            best = (root, "maj")
        if min_score > best_score and min_score >= 2:
            best_score = min_score
            best = (root, "min")
    if not best:
        return None
    root, q = best
    return f"{NOTE_NAMES[root]}:{q}"


def guess_key_from_pitch_classes(pc_counts: List[int]) -> Dict[str, Any]:
    # very lightweight key guess: choose key that maximizes in-scale coverage
    total = sum(pc_counts) or 1
    best = None
    best_score = -1.0
    for root in range(12):
        maj_scale = {(root + x) % 12 for x in MAJOR_SCALE}
        min_scale = {(root + x) % 12 for x in MINOR_SCALE}
        maj_cov = sum(pc_counts[i] for i in maj_scale) / total
        min_cov = sum(pc_counts[i] for i in min_scale) / total
        if maj_cov > best_score:
            best_score = maj_cov
            best = (root, "maj", maj_cov)
        if min_cov > best_score:
            best_score = min_cov
            best = (root, "min", min_cov)
    root, mode, cov = best
    key = f"{NOTE_NAMES[root]}:{mode}"
    out_of_scale = 1.0 - float(cov)
    return {"key_guess": key, "in_scale_ratio": float(cov), "out_of_scale_ratio": float(out_of_scale)}


def midi_global_summary(pm: pretty_midi.PrettyMIDI, midi_path: str) -> Dict[str, Any]:
    end_t = float(pm.get_end_time())
    times, tempi = pm.get_tempo_changes()
    tempo0 = float(tempi[0]) if len(tempi) else None
    num, den = time_signature(pm)

    notes = []
    inst_count = 0
    drum_inst_count = 0
    for inst in pm.instruments:
        inst_count += 1
        if inst.is_drum:
            drum_inst_count += 1
        notes.extend(inst.notes)

    note_count = len(notes)
    if note_count:
        pitch_min = int(min(n.pitch for n in notes))
        pitch_max = int(max(n.pitch for n in notes))
        vel_avg = float(sum(n.velocity for n in notes) / note_count)
    else:
        pitch_min = pitch_max = None
        vel_avg = None

    density = float(note_count / end_t) if end_t > 0 else None

    return {
        "midi_path": midi_path,
        "duration_s": end_t,
        "tempo_bpm_first": tempo0,
        "time_signature": f"{num}/{den}",
        "instrument_count": inst_count,
        "drum_instrument_count": drum_inst_count,
        "note_count": note_count,
        "note_density": density,
        "pitch_min": pitch_min,
        "pitch_max": pitch_max,
        "velocity_avg": vel_avg,
    }


def midi_symbolic_excerpt(
    pm: pretty_midi.PrettyMIDI,
    max_measures: int = 12,
    steps_per_beat: int = 4,
    keep_top_instruments: int = 2,
    include_drums: bool = False,
    max_events_total: int = 400,
) -> Dict[str, Any]:
    beats = list(pm.get_beats())
    end_t = float(pm.get_end_time())
    num, den = time_signature(pm)
    beats_per_measure = num

    measure_starts = [beats[i] for i in range(0, len(beats), beats_per_measure)]
    if not measure_starts:
        measure_starts = [0.0]

    mcount = min(max_measures, len(measure_starts))
    last_end = measure_starts[mcount] if mcount < len(measure_starts) else end_t

    insts = pick_main_instruments(pm, keep=keep_top_instruments, include_drums=include_drums)

    measures: Dict[int, Dict[str, Any]] = {m: {"m": m, "events": []} for m in range(1, mcount + 1)}
    events_total = 0

    for inst in insts:
        for n in inst.notes:
            if n.start >= last_end:
                continue
            if n.end <= 0:
                continue

            mi = bisect_right(measure_starts[:mcount], n.start) - 1
            if mi < 0:
                mi = 0
            if mi >= mcount:
                continue
            m = mi + 1

            bi = bisect_right(beats, n.start) - 1
            if bi < 0:
                bi = 0

            beat_in_measure = max(0, bi - mi * beats_per_measure)
            frac = 0.0
            if bi + 1 < len(beats):
                span = beats[bi + 1] - beats[bi]
                if span > 1e-9:
                    frac = (n.start - beats[bi]) / span
            beat_pos = float(beat_in_measure) + frac

            tempo = tempo_at(pm, n.start)
            sec_per_beat = 60.0 / max(tempo, 1e-6)
            dur_beats = max(0.0, (n.end - n.start) / sec_per_beat)

            s = int(round(beat_pos * steps_per_beat))
            d = max(1, int(round(dur_beats * steps_per_beat)))
            p = int(n.pitch)
            name = pretty_midi.note_number_to_name(p)

            measures[m]["events"].append(
                {"s": s, "d": d, "p": p, "n": name, "v": int(n.velocity), "prog": int(inst.program), "drum": bool(inst.is_drum)}
            )

            events_total += 1
            if events_total >= max_events_total:
                break
        if events_total >= max_events_total:
            break

    out_measures = []
    pc_counts = [0] * 12

    for m in range(1, mcount + 1):
        evs = measures[m]["events"]
        evs.sort(key=lambda x: (x["s"], x["p"]))
        evs = evs[:80]

        pcs = []
        for e in evs:
            if not e.get("drum"):
                pc = e["p"] % 12
                pcs.append(pc)
                pc_counts[pc] += 1

        chord = infer_triad(pcs)
        if evs:
            pr = [min(e["p"] for e in evs), max(e["p"] for e in evs)]
        else:
            pr = None

        # onset histogram (for rhythm judge)
        onset_bins = {}
        for e in evs:
            onset_bins[str(e["s"])] = onset_bins.get(str(e["s"]), 0) + 1

        out_measures.append(
            {"m": m, "chord": chord, "pitch_range": pr, "event_count": len(evs), "onset_bins": onset_bins, "events": evs}
        )

    key_info = guess_key_from_pitch_classes(pc_counts)

    times, tempi = pm.get_tempo_changes()
    tempo0 = float(tempi[0]) if len(tempi) else None

    return {
        "time_signature": f"{num}/{den}",
        "tempo_bpm_first": tempo0,
        "steps_per_beat": steps_per_beat,
        "max_measures": mcount,
        "key_hint": key_info,
        "note": "events: s=start_step_in_measure, d=duration_steps, steps_per_beat=4 -> 1 step ~ 1/16 note (approx)",
        "measures": out_measures,
    }


# -----------------------------
# Rule metrics (non-LLM judge)
# -----------------------------

def cosine_sim(a: List[float], b: List[float]) -> float:
    import math
    da = sum(x*x for x in a) ** 0.5
    db = sum(x*x for x in b) ** 0.5
    if da == 0 or db == 0:
        return 0.0
    return sum(x*y for x, y in zip(a, b)) / (da * db)


def compute_rule_metrics(pm: pretty_midi.PrettyMIDI, symbolic: Dict[str, Any]) -> Dict[str, Any]:
    # melody proxy: instrument with most notes (non-drum), sort by start, take pitches
    insts = [(len(i.notes), i) for i in pm.instruments if not i.is_drum]
    insts.sort(key=lambda x: x[0], reverse=True)
    melody_notes = []
    if insts:
        melody_notes = sorted(insts[0][1].notes, key=lambda n: (n.start, n.pitch))
    intervals = []
    for i in range(1, len(melody_notes)):
        intervals.append(abs(int(melody_notes[i].pitch) - int(melody_notes[i-1].pitch)))
    big_leaps = [x for x in intervals if x >= 8]  # >= minor 6th
    leap_rate = float(len(big_leaps) / max(1, len(intervals)))

    # density by measure from symbolic excerpt
    measures = symbolic.get("measures", [])
    event_counts = [m.get("event_count", 0) for m in measures]
    avg_events = float(sum(event_counts) / max(1, len(event_counts)))
    max_events = int(max(event_counts)) if event_counts else 0

    # chord stability: how often chord inferred
    chords = [m.get("chord") for m in measures if m.get("chord")]
    chord_mode = None
    if chords:
        from collections import Counter
        c = Counter(chords)
        chord_mode, chord_mode_cnt = c.most_common(1)[0]
        chord_consistency = float(chord_mode_cnt / max(1, len(chords)))
    else:
        chord_consistency = 0.0

    # out-of-scale ratio from key_hint
    key_hint = (symbolic.get("key_hint") or {})
    out_of_scale_ratio = float(key_hint.get("out_of_scale_ratio", 0.0))

    # repetition: measure-level pitch-class hist similarity
    # build hist(12) per measure
    hists: List[List[float]] = []
    for m in measures:
        pc = [0.0] * 12
        for e in m.get("events", []):
            if not e.get("drum"):
                pc[int(e["p"]) % 12] += 1.0
        hists.append(pc)

    rep_pairs = []
    for i in range(len(hists)):
        for j in range(i+1, len(hists)):
            sim = cosine_sim(hists[i], hists[j])
            rep_pairs.append(sim)
    rep_max = float(max(rep_pairs)) if rep_pairs else 0.0
    rep_high = float(sum(1 for x in rep_pairs if x >= 0.92) / max(1, len(rep_pairs))) if rep_pairs else 0.0

    # rhythm gridiness: onset concentration (if many on same few steps -> rigid)
    rigidity = 0.0
    if measures:
        concentrations = []
        for m in measures:
            bins = m.get("onset_bins", {})
            total = sum(bins.values()) or 1
            top = max(bins.values()) if bins else 0
            concentrations.append(top / total)
        rigidity = float(sum(concentrations) / max(1, len(concentrations)))

    # Score (0-100) from rules: start 100, apply penalties
    penalties = []
    score = 100.0

    # leap penalty
    if leap_rate > 0.45:
        p = 18.0
        score -= p
        penalties.append({"metric": "leap_rate", "value": leap_rate, "penalty": p, "hint": "大跳过多，旋律线可能不顺畅；可平滑跳进或增加级进连接。"})
    elif leap_rate > 0.30:
        p = 10.0
        score -= p
        penalties.append({"metric": "leap_rate", "value": leap_rate, "penalty": p, "hint": "大跳偏多；可在关键处做级进填充。"})

    # density penalty
    if avg_events > 45:
        p = 15.0
        score -= p
        penalties.append({"metric": "avg_events_per_measure", "value": avg_events, "penalty": p, "hint": "单位小节事件过密；可删弱拍装饰音或降低和弦堆叠。"})
    elif avg_events < 6:
        p = 10.0
        score -= p
        penalties.append({"metric": "avg_events_per_measure", "value": avg_events, "penalty": p, "hint": "单位小节事件过稀；可增加节奏型或伴奏层。"})

    # chord consistency
    if chord_consistency < 0.35 and len(chords) >= 4:
        p = 10.0
        score -= p
        penalties.append({"metric": "chord_consistency", "value": chord_consistency, "penalty": p, "hint": "和弦线索不稳定；可先确定调性与主进行，再做变化。"})

    # out of scale
    if out_of_scale_ratio > 0.45:
        p = 15.0
        score -= p
        penalties.append({"metric": "out_of_scale_ratio", "value": out_of_scale_ratio, "penalty": p, "hint": "离调音比例高；可明确调性或让离调音有功能性（属/经过/倚音）。"})
    elif out_of_scale_ratio > 0.30:
        p = 8.0
        score -= p
        penalties.append({"metric": "out_of_scale_ratio", "value": out_of_scale_ratio, "penalty": p, "hint": "离调音偏多；建议限制在过渡处或做和声解释。"})

    # repetition / too similar
    if rep_max > 0.97 and rep_high > 0.25:
        p = 10.0
        score -= p
        penalties.append({"metric": "repetition_similarity", "value": {"rep_max": rep_max, "rep_high_ratio": rep_high}, "penalty": p, "hint": "小节内容重复过强；可引入变化（转位、节奏变体、对位）。"})

    # rhythm rigidity
    if rigidity > 0.70:
        p = 8.0
        score -= p
        penalties.append({"metric": "rhythm_rigidity", "value": rigidity, "penalty": p, "hint": "起音过度集中，律动可能僵硬；可加入切分/弱拍强调或变化节奏型。"})

    score = float(max(0.0, min(100.0, score)))
    return {
        "rule_score_total": score,
        "leap_rate": leap_rate,
        "avg_events_per_measure": avg_events,
        "max_events_per_measure": max_events,
        "key_hint": key_hint,
        "chord_consistency": chord_consistency,
        "repetition": {"rep_max": rep_max, "rep_high_ratio": rep_high},
        "rhythm_rigidity": rigidity,
        "penalties": penalties,
    }


def rule_based_edit_plan(rule_metrics: Dict[str, Any]) -> List[Dict[str, Any]]:
    plan = []
    # map penalties to actions
    for p in rule_metrics.get("penalties", []):
        metric = p.get("metric")
        if metric == "leap_rate":
            plan.append({"measure": None, "action": "smooth_leaps", "details": "降低连续大跳；在大跳前后增加级进连接或改变旋律走向。", "expected_effect": "旋律线更连贯，听感更自然。"})
        elif metric == "avg_events_per_measure":
            v = p.get("value", 0)
            if isinstance(v, (int, float)) and v > 20:
                plan.append({"measure": None, "action": "reduce_density", "details": "删弱拍装饰音/重复音；限制每拍和弦堆叠数量。", "expected_effect": "织体更清晰，避免拥挤。"})
            else:
                plan.append({"measure": None, "action": "add_rhythm_layer", "details": "在空白处补充简单伴奏/节奏型，保持一致律动。", "expected_effect": "更有推动感与完整性。"})
        elif metric == "out_of_scale_ratio":
            plan.append({"measure": None, "action": "clarify_key", "details": "明确调性与主音；把离调音限制为功能性经过/倚音，或用和弦解释离调。", "expected_effect": "和声更稳定，减少突兀感。"})
        elif metric == "chord_consistency":
            plan.append({"measure": None, "action": "stabilize_progression", "details": "先确定4-8小节主和声进行（如 I–vi–IV–V），再做转位与装饰。", "expected_effect": "段落更统一，结构更清晰。"})
        elif metric == "repetition_similarity":
            plan.append({"measure": None, "action": "vary_motifs", "details": "对重复小节做变奏：节奏变体、转位、移调、对位线或动态变化。", "expected_effect": "保留动机又避免机械重复。"})
        elif metric == "rhythm_rigidity":
            plan.append({"measure": None, "action": "add_syncopation", "details": "加入切分/弱拍强调，或对部分起音做延后/提前的小变化。", "expected_effect": "律动更灵活、更有呼吸。"})
    # de-dup by action
    seen = set()
    out = []
    for item in plan:
        a = item["action"]
        if a in seen:
            continue
        seen.add(a)
        out.append(item)
    return out[:10]


# -----------------------------
# Auto-edit (safe transformations) -> new MIDI
# -----------------------------

@dataclass
class EditOptions:
    quantize: bool = True
    denoise: bool = True
    vel_smooth: bool = True
    density: bool = True
    steps_per_beat: int = 4
    min_note_dur_s: float = 0.04
    min_velocity: int = 12
    max_notes_per_step: int = 4


def quantize_time_to_grid(beats: List[float], t: float, steps_per_beat: int) -> float:
    # map time to (beat_index + frac) then to steps, round, back to time
    if not beats:
        return t
    i = bisect_right(beats, t) - 1
    if i < 0:
        i = 0
    if i >= len(beats) - 1:
        return t
    span = beats[i+1] - beats[i]
    if span <= 1e-9:
        return t
    frac = (t - beats[i]) / span
    beat_pos = i + frac
    step_pos = round(beat_pos * steps_per_beat)
    beat_pos_q = step_pos / steps_per_beat
    i2 = int(beat_pos_q)
    frac2 = beat_pos_q - i2
    if i2 < 0:
        i2 = 0
        frac2 = 0.0
    if i2 >= len(beats) - 1:
        i2 = len(beats) - 2
        frac2 = 1.0
    return beats[i2] + frac2 * (beats[i2+1] - beats[i2])


def apply_auto_edit(pm: pretty_midi.PrettyMIDI, opts: EditOptions) -> pretty_midi.PrettyMIDI:
    beats = list(pm.get_beats())
    edited = pretty_midi.PrettyMIDI(initial_tempo=120.0)
    edited.time_signature_changes = pm.time_signature_changes
    edited.key_signature_changes = pm.key_signature_changes

    for inst in pm.instruments:
        new_inst = pretty_midi.Instrument(program=inst.program, is_drum=inst.is_drum, name=inst.name)
        notes = sorted(inst.notes, key=lambda n: (n.start, n.pitch))

        # denoise + quantize
        q_notes = []
        for n in notes:
            st, en = float(n.start), float(n.end)
            v = int(n.velocity)

            if opts.denoise:
                if (en - st) < opts.min_note_dur_s:
                    continue
                if v < opts.min_velocity:
                    continue

            if opts.quantize and beats:
                stq = quantize_time_to_grid(beats, st, opts.steps_per_beat)
                enq = quantize_time_to_grid(beats, en, opts.steps_per_beat)
                if enq <= stq:
                    enq = stq + max(0.03, (en - st))
                st, en = stq, enq

            q_notes.append(pretty_midi.Note(velocity=v, pitch=int(n.pitch), start=st, end=en))

        # velocity smooth
        if opts.vel_smooth and q_notes:
            # simple moving average on velocity in temporal order
            w = 3
            vels = [nn.velocity for nn in q_notes]
            sm = []
            for i in range(len(vels)):
                lo = max(0, i - w)
                hi = min(len(vels), i + w + 1)
                avg = sum(vels[lo:hi]) / (hi - lo)
                sm.append(int(round(avg)))
            for nn, nv in zip(q_notes, sm):
                nn.velocity = max(25, min(110, nv))

        # density thinning: per ~grid step keep top velocities
        if opts.density and beats and q_notes:
            bucket = {}
            for nn in q_notes:
                st = nn.start
                # bucket by quantized step (approx)
                i = bisect_right(beats, st) - 1
                if i < 0:
                    i = 0
                if i >= len(beats) - 1:
                    key = (len(beats)-2, opts.steps_per_beat-1)
                else:
                    span = beats[i+1] - beats[i]
                    frac = (st - beats[i]) / span if span > 1e-9 else 0.0
                    step = int(round(frac * opts.steps_per_beat))
                    step = max(0, min(opts.steps_per_beat-1, step))
                    key = (i, step)
                bucket.setdefault(key, []).append(nn)

            kept = []
            for k, lst in bucket.items():
                lst.sort(key=lambda n: n.velocity, reverse=True)
                kept.extend(lst[:opts.max_notes_per_step])
            q_notes = sorted(kept, key=lambda n: (n.start, n.pitch))

        new_inst.notes = q_notes
        edited.instruments.append(new_inst)

    return edited


# -----------------------------
# LLM calls (judges / moderator / chair)
# -----------------------------

def llm_client() -> OpenAI:
    base_url = os.environ.get("DEEPSEEK_BASE_URL", "https://api.deepseek.com/v1")
    api_key = os.environ["DEEPSEEK_API_KEY"]
    return OpenAI(api_key=api_key, base_url=base_url)


def call_llm_json(client: OpenAI, model: str, system: str, user: str, max_try: int = 2, max_tokens: int = 1800) -> Dict[str, Any]:
    last_err = None
    for _ in range(max_try):
        resp = None
        for attempt in range(5):
            try:
                resp = client.chat.completions.create(
            model=model,
            messages=[{"role": "system", "content": system}, {"role": "user", "content": user}],
            temperature=0.2,
            max_tokens=max_tokens,
        )
                
                break
            except (APIConnectionError, httpx.RemoteProtocolError, httpx.ReadTimeout, httpx.ConnectError) as e:
                if attempt == 4:
                    raise
                time.sleep(min(2 ** attempt, 8) + random.random())
        txt = resp.choices[0].message.content or ""
        try:
            return safe_json_loads(txt)
        except Exception as e:
            last_err = e
            fix = client.chat.completions.create(
                model=model,
                messages=[
                    {"role": "system", "content": "你是 JSON 修复器。只输出可被 json.loads 解析的 JSON。"},
                    {"role": "user", "content": "把下面内容改写成严格 JSON（只输出 JSON）。\n\n" + txt},
                ],
                temperature=0.0,
                max_tokens=max_tokens,
            )
            txt2 = fix.choices[0].message.content or ""
            try:
                return safe_json_loads(txt2)
            except Exception as e2:
                last_err = e2
    raise last_err or RuntimeError("LLM JSON parse failed.")


def compress_peer(j: Dict[str, Any]) -> Dict[str, Any]:
    return {
        "judge_name": j.get("judge_name"),
        "focus": j.get("focus"),
        "score": j.get("score"),
        "pros": (j.get("pros") or [])[:4],
        "cons": (j.get("cons") or [])[:4],
        "suggestions": (j.get("suggestions") or [])[:4],
        "rationale": (j.get("rationale") or "")[:240],
    }


def moderator_disagreements(round1: Dict[str, Any]) -> Dict[str, Any]:
    # compute quick score variance + let LLM turn into structured disagreements
    scores = [int(v.get("score", 0)) for v in round1.values()]
    if scores:
        mean = sum(scores) / len(scores)
        var = sum((x - mean) ** 2 for x in scores) / len(scores)
    else:
        var = 0.0

    client = llm_client()
    system = (
        "你是评审团主持人（moderator）。你必须只输出一个 JSON 对象。\n"
        "目标：找出评委之间的主要分歧点，并提出需要在复议中解决的问题。\n"
        "schema: {"
        "\"score_variance\": float,"
        "\"disagreements\": [{\"topic\": str, \"why\": str, \"measures\": [int], \"questions\": [str]}],"
        "\"consensus_points\": [str]"
        "}"
    )
    user = (
        f"评委初评汇总(JSON)：{json.dumps({k: compress_peer(v) for k,v in round1.items()}, ensure_ascii=False)}\n\n"
        f"分数方差提示：{var:.3f}\n\n"
        "输出 disagreements 至少 2 条，优先引用具体小节（若无法确定小节，可 measures=[]）。"
    )
    out = call_llm_json(client, DEFAULT_MODEL, system, user, max_try=2, max_tokens=1400)
    out["score_variance"] = float(out.get("score_variance", var))
    if "disagreements" not in out:
        out["disagreements"] = []
    if "consensus_points" not in out:
        out["consensus_points"] = []
    return out


def llm_deliberation_v4(
    global_meta: Dict[str, Any],
    symbolic: Dict[str, Any],
    rule_metrics: Dict[str, Any],
    target_style: str,
    intended_use: str,
    model_judge: str,
    model_chair: str,
) -> Dict[str, Any]:
    client = llm_client()
    global_s = json.dumps(global_meta, ensure_ascii=False)
    sym_s = json.dumps(symbolic, ensure_ascii=False)
    rule_s = json.dumps(rule_metrics, ensure_ascii=False)

    judge_system = (
        "你是音乐评审。你必须只输出一个 JSON 对象，不能输出任何额外文本。\n"
        "评分范围 0-25（整数）。请尽量引用具体小节编号（第X小节）。\n"
        "你需要结合：符号事件、和弦/调性线索、以及规则指标（rule_metrics）来评价。\n"
        "schema: {"
        "\"judge_name\": str, \"focus\": str, \"score\": int, "
        "\"pros\": [str], \"cons\": [str], \"suggestions\": [str], "
        "\"rationale\": str"
        "}"
    )

    ctx = (
        f"目标风格：{target_style}\n"
        f"使用场景：{intended_use}\n"
        "请按目标风格/场景调整尺度：比如背景音乐更重视一致性与可听性，练习曲更重视结构与规范。"
    )

    # Round 1
    round1: Dict[str, Any] = {}
    for j in JUDGES:
        user = (
            f"{ctx}\n\n"
            f"评审维度：{j['focus']}\n\n"
            f"全局摘要(JSON)：{global_s}\n\n"
            f"规则指标(JSON)：{rule_s}\n\n"
            f"符号事件摘要(JSON)：{sym_s}\n\n"
            "按 schema 输出严格 JSON。"
        )
        out = call_llm_json(client, model_judge, judge_system, user, max_try=2, max_tokens=1600)
        out["judge_name"] = j["name"]
        out["focus"] = j["focus"]
        out["score"] = clamp_int(out.get("score", 0), 0, 25)
        round1[j["name"]] = out

    # Moderator: disagreements + questions
    mod = moderator_disagreements(round1)

    revise_system = (
        "你是音乐评审。你已完成初评，现在看到了其他评委摘要 + 主持人的分歧清单。\n"
        "请复议：必要时修正分数与建议，使其更一致、更可执行。\n"
        "你必须只输出一个 JSON 对象，不能输出任何额外文本。schema 同初评。"
    )

    # Round 2
    round2: Dict[str, Any] = {}
    peers_comp = {k: compress_peer(v) for k, v in round1.items()}
    for j in JUDGES:
        me = round1[j["name"]]
        others = [peers_comp[k] for k in peers_comp if k != j["name"]]
        user = (
            f"{ctx}\n\n"
            f"你的评审维度：{j['focus']}\n\n"
            f"全局摘要(JSON)：{global_s}\n\n"
            f"规则指标(JSON)：{rule_s}\n\n"
            f"符号事件摘要(JSON)：{sym_s}\n\n"
            f"你的初评(JSON)：{json.dumps(compress_peer(me), ensure_ascii=False)}\n\n"
            f"其他评委摘要(JSON 数组)：{json.dumps(others, ensure_ascii=False)}\n\n"
            f"主持人分歧清单(JSON)：{json.dumps(mod, ensure_ascii=False)}\n\n"
            "按 schema 输出严格 JSON。"
        )
        out = call_llm_json(client, model_judge, revise_system, user, max_try=2, max_tokens=1700)
        out["judge_name"] = j["name"]
        out["focus"] = j["focus"]
        out["score"] = clamp_int(out.get("score", me.get("score", 0)), 0, 25)
        round2[j["name"]] = out

    # Chair: output + edit plan + disagreements
    harmony = int(round2["harmony_judge"]["score"])
    rhythm = int(round2["rhythm_judge"]["score"])
    structure = int(round2["structure_judge"]["score"])
    style = int(round2["style_judge"]["score"])
    llm_total_guess = harmony + rhythm + structure + style

    chair_system = (
        "你是总评/仲裁。你必须只输出一个 JSON 对象，不能输出任何额外文本。\n"
        "分数范围：各维度 0-25，总分 0-100（整数）。\n"
        "请尽量引用具体小节编号。\n"
        "schema: {"
        "\"score_total\": int,"
        "\"scores\": {\"harmony\": int, \"rhythm\": int, \"structure\": int, \"style\": int},"
        "\"pros\": [str],"
        "\"cons\": [str],"
        "\"suggestions\": [str],"
        "\"disagreements\": [{\"topic\": str, \"why\": str, \"measures\": [int], \"resolution\": str}],"
        "\"edit_plan\": [{\"measure\": int|null, \"action\": str, \"details\": str, \"expected_effect\": str}]"
        "}"
    )

    chair_user = (
        f"{ctx}\n\n"
        f"全局摘要(JSON)：{global_s}\n\n"
        f"规则指标(JSON)：{rule_s}\n\n"
        f"符号事件摘要(JSON)：{sym_s}\n\n"
        f"主持人分歧清单(JSON)：{json.dumps(mod, ensure_ascii=False)}\n\n"
        f"评委最终输出（Round2）：{json.dumps({k: compress_peer(v) for k,v in round2.items()}, ensure_ascii=False)}\n\n"
        "请给出最终结论：分数、优缺点、建议、分歧裁决，以及可执行 edit_plan（动作要具体，如 reduce_density / smooth_leaps / clarify_key / stabilize_progression / add_syncopation / vary_motifs）。"
    )

    chair = call_llm_json(client, model_chair, chair_system, chair_user, max_try=2, max_tokens=1700)

    chair.setdefault("scores", {"harmony": harmony, "rhythm": rhythm, "structure": structure, "style": style})
    chair["scores"]["harmony"] = clamp_int(chair["scores"].get("harmony", harmony), 0, 25, harmony)
    chair["scores"]["rhythm"] = clamp_int(chair["scores"].get("rhythm", rhythm), 0, 25, rhythm)
    chair["scores"]["structure"] = clamp_int(chair["scores"].get("structure", structure), 0, 25, structure)
    chair["scores"]["style"] = clamp_int(chair["scores"].get("style", style), 0, 25, style)

    chair["score_total"] = clamp_int(chair.get("score_total", llm_total_guess), 0, 100, llm_total_guess)
    chair.setdefault("pros", [])
    chair.setdefault("cons", [])
    chair.setdefault("suggestions", [])
    chair.setdefault("disagreements", [])
    chair.setdefault("edit_plan", [])

    return {
        "round1": round1,
        "moderator": mod,
        "round2": round2,
        "chair": chair,
        "llm_total_guess": llm_total_guess,
    }


# -----------------------------
# Cache / IO
# -----------------------------

def load_cache(cache_path: Path) -> Optional[Dict[str, Any]]:
    try:
        return json.loads(cache_path.read_text(encoding="utf-8"))
    except Exception:
        return None


def write_json(path: Path, obj: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(obj, ensure_ascii=False, indent=2), encoding="utf-8")


def list_midis(folder: Path) -> List[Path]:
    return sorted([p for p in folder.glob("**/*") if p.suffix.lower() in {".mid", ".midi"}])


def write_summary_csv(rows: List[Dict[str, Any]], csv_path: Path) -> None:
    csv_path.parent.mkdir(parents=True, exist_ok=True)
    if not rows:
        csv_path.write_text("", encoding="utf-8-sig")
        return
    keys = list(rows[0].keys())
    with csv_path.open("w", newline="", encoding="utf-8-sig") as f:
        w = csv.DictWriter(f, fieldnames=keys)
        w.writeheader()
        for r in rows:
            w.writerow(r)


def aggregate_rows(rows: List[Dict[str, Any]]) -> Dict[str, Any]:
    # numeric mean for common fields
    nums = ["score_total", "rule_score_total", "final_score_total", "harmony", "rhythm", "structure", "style"]
    agg = {}
    for k in nums:
        vals = [r.get(k) for r in rows if isinstance(r.get(k), (int, float))]
        agg[k] = float(sum(vals) / len(vals)) if vals else None
    agg["n"] = len(rows)
    return agg


# -----------------------------
# Main evaluation v4
# -----------------------------

def evaluate_one_v4(
    midi_path: Path,
    out_dir: Path,
    cache_dir: Path,
    model_judge: str,
    model_chair: str,
    max_measures: int,
    target_style: str,
    intended_use: str,
    rule_weight: float,
    auto_edit: str,
    do_after: bool,
) -> Dict[str, Any]:
    midi_bytes = midi_path.read_bytes()
    midi_hash = sha256_bytes(midi_bytes)

    settings = {
        "model_judge": model_judge,
        "model_chair": model_chair,
        "max_measures": max_measures,
        "target_style": target_style,
        "intended_use": intended_use,
        "rule_weight": rule_weight,
        "auto_edit": auto_edit,
        "do_after": do_after,
        "version": "v4",
    }
    settings_hash = sha256_bytes(stable_json(settings).encode("utf-8"))[:16]
    cache_path = cache_dir / f"{midi_hash}_{settings_hash}.json"

    cached = load_cache(cache_path)
    if cached:
        # still write report to out_dir for convenience
        report_path = out_dir / f"{midi_path.stem}.report_v4.json"
        write_json(report_path, cached)
        return cached

    pm = pretty_midi.PrettyMIDI(str(midi_path))
    global_meta = midi_global_summary(pm, str(midi_path))
    symbolic = midi_symbolic_excerpt(pm, max_measures=max_measures)
    rule_metrics = compute_rule_metrics(pm, symbolic)

    # LLM multi-agent deliberation
    llm_pack = llm_deliberation_v4(
        global_meta=global_meta,
        symbolic=symbolic,
        rule_metrics=rule_metrics,
        target_style=target_style,
        intended_use=intended_use,
        model_judge=model_judge,
        model_chair=model_chair,
    )

    chair = llm_pack["chair"]
    llm_total = int(chair.get("score_total", llm_pack["llm_total_guess"]))
    rule_total = float(rule_metrics.get("rule_score_total", 0.0))
    rule_weight = max(0.0, min(1.0, float(rule_weight)))
    final_total = float((1.0 - rule_weight) * llm_total + rule_weight * rule_total)
    final_total_i = clamp_int(round(final_total), 0, 100, llm_total)

    # merge edit plans: rule plan + chair plan (chair first)
    chair_plan = chair.get("edit_plan") or []
    if not isinstance(chair_plan, list):
        chair_plan = []
    rb_plan = rule_based_edit_plan(rule_metrics)
    merged_plan = chair_plan + rb_plan
    # de-dup by action+measure
    seen = set()
    plan_out = []
    for it in merged_plan:
        if not isinstance(it, dict):
            continue
        m = it.get("measure", None)
        a = str(it.get("action", "")).strip()
        if not a:
            continue
        key = (m, a)
        if key in seen:
            continue
        seen.add(key)
        it.setdefault("details", "")
        it.setdefault("expected_effect", "")
        plan_out.append(it)
        if len(plan_out) >= 16:
            break

    report = {
        "version": "music_eval_v4",
        "ts": now_ts(),
        "file": str(midi_path),
        "cache_key": f"{midi_hash}_{settings_hash}",
        "run_meta": settings,
        "target_style": target_style,
        "intended_use": intended_use,

        "midi_meta": global_meta,
        "symbolic_excerpt": symbolic,

        "scores": chair.get("scores", {}),
        "score_total": llm_total,
        "rule_metrics": rule_metrics,
        "rule_score_total": rule_total,
        "final_score_total": final_total_i,
        "rule_weight": rule_weight,

        "pros": chair.get("pros", []),
        "cons": chair.get("cons", []),
        "suggestions": chair.get("suggestions", []),
        "disagreements": chair.get("disagreements", []),
        "edit_plan": plan_out,

        "judge_traces_round1": llm_pack["round1"],
        "moderator": llm_pack["moderator"],
        "judge_traces": llm_pack["round2"],
    }

    # optional: closed-loop after-edit
    if do_after:
        opts = EditOptions(
            quantize=("Q" in auto_edit),
            denoise=("N" in auto_edit),
            vel_smooth=("V" in auto_edit),
            density=("D" in auto_edit),
        )
        pm2 = pretty_midi.PrettyMIDI(str(midi_path))
        edited = apply_auto_edit(pm2, opts)
        edited_path = out_dir / f"{midi_path.stem}.edited.mid"
        edited.write(str(edited_path))

        # re-evaluate AFTER (no recursion; disable after within after)
        after_settings = dict(settings)
        after_settings["do_after"] = False
        # reuse same cache policy but separate key
        after_hash = sha256_bytes(edited_path.read_bytes())
        after_settings_hash = sha256_bytes(stable_json(after_settings).encode("utf-8"))[:16]
        after_cache_path = cache_dir / f"{after_hash}_{after_settings_hash}.json"

        after_cached = load_cache(after_cache_path)
        if after_cached:
            after_report = after_cached
        else:
            pm_after = pretty_midi.PrettyMIDI(str(edited_path))
            g_after = midi_global_summary(pm_after, str(edited_path))
            s_after = midi_symbolic_excerpt(pm_after, max_measures=max_measures)
            r_after = compute_rule_metrics(pm_after, s_after)
            llm_after = llm_deliberation_v4(
                global_meta=g_after, symbolic=s_after, rule_metrics=r_after,
                target_style=target_style, intended_use=intended_use,
                model_judge=model_judge, model_chair=model_chair
            )
            chair_a = llm_after["chair"]
            llm_total_a = int(chair_a.get("score_total", llm_after["llm_total_guess"]))
            rule_total_a = float(r_after.get("rule_score_total", 0.0))
            final_total_a = float((1.0 - rule_weight) * llm_total_a + rule_weight * rule_total_a)
            final_total_a_i = clamp_int(round(final_total_a), 0, 100, llm_total_a)

            after_report = {
                "version": "music_eval_v4_after",
                "ts": now_ts(),
                "file": str(edited_path),
                "cache_key": f"{after_hash}_{after_settings_hash}",
                "run_meta": after_settings,
                "target_style": target_style,
                "intended_use": intended_use,
                "midi_meta": g_after,
                "symbolic_excerpt": s_after,
                "scores": chair_a.get("scores", {}),
                "score_total": llm_total_a,
                "rule_metrics": r_after,
                "rule_score_total": rule_total_a,
                "final_score_total": final_total_a_i,
                "rule_weight": rule_weight,
                "pros": chair_a.get("pros", []),
                "cons": chair_a.get("cons", []),
                "suggestions": chair_a.get("suggestions", []),
                "disagreements": chair_a.get("disagreements", []),
                "edit_plan": chair_a.get("edit_plan", []),
            }
            write_json(after_cache_path, after_report)

        report["auto_edit"] = {
            "enabled": True,
            "options": auto_edit,
            "edited_midi": str(edited_path),
            "after_report": after_report,
            "delta": {
                "final_score_total": (after_report.get("final_score_total", None), report["final_score_total"]),
            },
        }

    # write outputs
    out_dir.mkdir(parents=True, exist_ok=True)
    cache_dir.mkdir(parents=True, exist_ok=True)
    report_path = out_dir / f"{midi_path.stem}.report_v4.json"
    write_json(report_path, report)
    write_json(cache_path, report)
    return report


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--midi", type=str, default=None, help="single midi file")
    ap.add_argument("--midi_dir", type=str, default=None, help="folder of midis")
    ap.add_argument("--compare_dir", type=str, default=None, help="optional: compare another folder")
    ap.add_argument("--out_dir", type=str, default="music_eval_v4_out")
    ap.add_argument("--cache_dir", type=str, default=".cache_music_eval_v4")

    ap.add_argument("--model_judge", type=str, default=DEFAULT_MODEL)
    ap.add_argument("--model_chair", type=str, default=DEFAULT_MODEL)
    ap.add_argument("--max_measures", type=int, default=12)

    ap.add_argument("--target_style", type=str, default="general")
    ap.add_argument("--intended_use", type=str, default="demo")

    ap.add_argument("--rule_weight", type=float, default=0.25, help="0..1, weight of rule_score in final_score_total")
    ap.add_argument("--auto_edit", type=str, default="QNV", help="subset of Q N V D (quantize/denoise/vel_smooth/density)")
    ap.add_argument("--after", action="store_true", help="enable after-edit re-evaluation loop")

    args = ap.parse_args()

    if not os.getenv("DEEPSEEK_API_KEY"):
        raise SystemExit("Missing env var: DEEPSEEK_API_KEY")
    # base url optional

    out_dir = Path(args.out_dir)
    cache_dir = Path(args.cache_dir)

    def run_folder(folder: Path, tag: str) -> Tuple[List[Dict[str, Any]], Dict[str, Any]]:
        rows = []
        reports = []
        midis = list_midis(folder)
        if not midis:
            raise SystemExit(f"No MIDI files under: {folder}")
        for p in midis:
            rep = evaluate_one_v4(
                midi_path=p,
                out_dir=out_dir / tag,
                cache_dir=cache_dir,
                model_judge=args.model_judge,
                model_chair=args.model_chair,
                max_measures=args.max_measures,
                target_style=args.target_style,
                intended_use=args.intended_use,
                rule_weight=args.rule_weight,
                auto_edit=args.auto_edit,
                do_after=bool(args.after),
            )
            sc = rep.get("scores", {}) or {}
            rows.append({
                "file": p.name,
                "final_score_total": rep.get("final_score_total"),
                "score_total": rep.get("score_total"),
                "rule_score_total": rep.get("rule_score_total"),
                "harmony": sc.get("harmony"),
                "rhythm": sc.get("rhythm"),
                "structure": sc.get("structure"),
                "style": sc.get("style"),
                "report": str((out_dir / tag / f"{p.stem}.report_v4.json").resolve()),
            })
            reports.append(rep)
            print(f"[OK] {tag} {p.name} -> final={rep.get('final_score_total')} (llm={rep.get('score_total')}, rule={rep.get('rule_score_total')})")

        agg = aggregate_rows(rows)
        write_summary_csv(rows, out_dir / tag / "summary.csv")
        write_json(out_dir / tag / "aggregate.json", agg)
        return rows, agg

    # single file
    if args.midi:
        p = Path(args.midi)
        rep = evaluate_one_v4(
            midi_path=p,
            out_dir=out_dir / "single",
            cache_dir=cache_dir,
            model_judge=args.model_judge,
            model_chair=args.model_chair,
            max_measures=args.max_measures,
            target_style=args.target_style,
            intended_use=args.intended_use,
            rule_weight=args.rule_weight,
            auto_edit=args.auto_edit,
            do_after=bool(args.after),
        )
        out_path = (out_dir / "single" / f"{p.stem}.report_v4.json").resolve()
        print("OK ->", out_path)
        print("final_score_total =", rep.get("final_score_total"))
        return

    # folder / compare
    if not args.midi_dir:
        raise SystemExit("Provide --midi <file> or --midi_dir <folder>")

    base_folder = Path(args.midi_dir)
    _, agg_a = run_folder(base_folder, "A")

    if args.compare_dir:
        comp_folder = Path(args.compare_dir)
        _, agg_b = run_folder(comp_folder, "B")
        compare = {"A": agg_a, "B": agg_b}
        # delta B - A for numeric means
        delta = {}
        for k, va in agg_a.items():
            vb = agg_b.get(k)
            if isinstance(va, (int, float)) and isinstance(vb, (int, float)):
                delta[k] = float(vb - va)
        compare["delta_B_minus_A"] = delta
        write_json(out_dir / "compare.json", compare)
        print("COMPARE OK ->", (out_dir / "compare.json").resolve())


if __name__ == "__main__":
    main()
